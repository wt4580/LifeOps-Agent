# ========================================
# LifeOps-Agent 环境配置文件（示例）
# ========================================
# 使用方法：
# 1. 复制此文件为 .env（同一目录下）
# 2. 至少填写 QWEN_API_KEY
# 3. 其他配置项都有默认值，可根据需要调整
# ========================================

# -------------------------
# LLM 基础配置（必填）
# -------------------------
# 阿里云 DashScope API Key（从 https://dashscope.console.aliyun.com/ 获取）
QWEN_API_KEY=your-api-key-here

# 模型名称（默认 qwen-turbo）
# 测试可用: qwen-turbo, kimi-k2.6（通过 DashScope 兼容接口）
QWEN_MODEL=qwen-turbo

# DashScope OpenAI 兼容接口地址
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# -------------------------
# 文档目录配置
# -------------------------
# 本地知识库文档所在目录（支持 PDF/TXT/PNG）
DOCS_DIR=/path/to/your/docs

# Tesseract OCR 路径（如果使用 PNG 图片识别，可选）
# Windows 示例: C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=

# 日志级别（可选，默认 INFO）
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -------------------------
# OCR 配置（PNG 图片文字识别）
# -------------------------
# OCR 语言包（chi_sim=简体中文, eng=英文）
OCR_LANG=chi_sim+eng

# PSM 页面分割模式（6=假设统一文本块）
OCR_PSM=6

# OEM 引擎模式（3=默认，使用 LSTM + 传统引擎）
OCR_OEM=3

# OCR 调试模式（true/false）
OCR_DEBUG=false

# -------------------------
# RAG 检索配置
# -------------------------
# 检索后端选择
# - bm25: 仅使用 BM25 关键词检索（最稳定，无需下载模型）
# - langchain: 仅使用向量检索（需下载 embedding 模型）
# - hybrid: BM25 + 向量融合（推荐，需下载 embedding 模型）
RAG_BACKEND=bm25
# 返回结果数量
RAG_TOP_K=5

# 候选集大小（用于混合检索）
RAG_CANDIDATE_K=24
# 向量索引存储目录
RAG_VECTOR_DIR=app/data/vector/faiss

# Embedding 模型（hybrid/langchain 后端需要）
# 留空则首次运行时自动从 HuggingFace Hub 下载
# 中国大陆用户可设置 HF_ENDPOINT=https://hf-mirror.com 加速下载
# RAG_EMBED_MODEL_LOCAL=/path/to/bge-small-zh-v1.5

# 重排序模型（可选，hybrid 后端推荐启用）
# 留空则首次运行时自动从 HuggingFace Hub 下载
# RAG_RERANK_MODEL_LOCAL=/path/to/bge-reranker-base

# 是否启用重排序（true/false）
RAG_USE_RERANK=true

# 文档分块大小（字符数）
RAG_CHUNK_SIZE=600

# 分块重叠大小（字符数）
RAG_CHUNK_OVERLAP=120

# 证据可信度阈值（低于此值会拒答）
RAG_EVIDENCE_MIN_SCORE=0.02

# 无证据时的回复模板
RAG_NO_EVIDENCE_TEMPLATE=当前证据不足以支持确定结论。我可以继续按关键词重检，或请你提供更具体的文件名/术语。

# -------------------------
# 主动建议配置
# -------------------------
# 主动建议触发阈值（0-1之间）
PROACTIVE_ADVICE_THRESHOLD=0.62

# 待办提前提醒时间（小时）
PROACTIVE_TODO_HOURS=72

# 个人事件读取时间窗口（小时，168=7天）
PROACTIVE_EVENT_WINDOW_HOURS=168

# -------------------------
# 个人记忆范围配置
# -------------------------
# 记忆可见范围
# - session: 仅当前会话可见
# - global: 跨会话共享（单用户推荐）
PERSONAL_MEMORY_SCOPE=global

# 全局记忆的用户 ID
PERSONAL_MEMORY_GLOBAL_ID=default_user

# -------------------------
# 聊天历史留存策略
# -------------------------
# 单会话消息数上限（超过后触发压缩）
CHAT_RETENTION_LIMIT=1000

# 压缩后保留的消息数
CHAT_PRUNE_TARGET=800

# -------------------------
# 高德天气配置
# -------------------------
# 从 https://console.amap.com/dev/key/app 申请 Web 服务 Key
# 留空时 query_weather 会提示用户配置。
AMAP_WEATHER_KEY=your-amap-key-here

# 用户未说明城市、且 profile 中也没有"默认城市:XX"时的兜底城市
DEFAULT_WEATHER_CITY=北京

# 天气结果内存缓存秒数（节省免费额度，默认 300）
WEATHER_CACHE_TTL_SECONDS=300

# -------------------------
# 主动推送配置（Server酱）
# -------------------------
# 在 https://sct.ftqq.com 注册后获取 SendKey
# 配置后，LifeOps 会通过微信推送待办提醒、复盘等通知
# SERVERCHAN_KEY=your-sendkey-here

# Pushover（备选推送，$5 一次性购买）
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=

# -------------------------
# 定时推送计划（APScheduler）
# -------------------------
# 晨间简报推送时间（HH:MM），留空则不推送
SCHEDULE_MORNING_BRIEFING=08:00
# 晚间复盘推送时间（HH:MM），留空则不推送
SCHEDULE_DAILY_REVIEW=21:00
